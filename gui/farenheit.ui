   <string notr="true">QDialog {
    background-color: #f7f9fc;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    color: #2d3436;
}

/* Labels de texto */
QLabel {
    color: #4a5568;
}

QLabel#titulon {
    color: #4a5568;
	font-size: 28pt;
	font-weight: bold;
}


/* Label del resultado */
QLabel#resultadoCelsius {
    background-color: #eef4ff;
    border: 1px solid #d0d7e2;
    border-radius: 8px;
    padding: 8px;
    font-size: 11pt;
    font-weight: bold;
    color: #2c5282;
}

/* Campo de entrada */
QLineEdit {
    background-color: white;
    border: 1px solid #dcdfe6;
    border-radius: 8px;
    padding: 8px;
    font-size: 11pt;
}

QLineEdit:focus {
    border: 2px solid #3da5ff;
}

/* Botón convertir */
QPushButton#btnConvertir {
    background-color: #3da5ff;
    color: white;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 600;
}

QPushButton#btnConvertir:hover {
    background-color: #5ab3ff;
}

QPushButton#btnConvertir:pressed {
    background-color: #2c8ce0;
}

/* Botón cerrar */
QPushButton#btnCerrar {
    background-color: #e9ecef;
    color: #495057;
    border-radius: 8px;
    padding: 8px 16px;
}

QPushButton#btnCerrar:hover {
    background-color: #dee2e6;
}</string>
