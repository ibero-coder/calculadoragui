   <string notr="true">QDialog {
    background-color: #f7f9fc;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    color: #2d3436;
}

/* Título */
QLabel#labelTitulo {
    font-size: 14pt;
    font-weight: 600;
    color: #2c5282;
}

/* Labels */
QLabel {
    color: #4a5568;
}

/* Resultado */
QLabel#resultado {
    background-color: #eef4ff;
    border: 1px solid #d0d7e2;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    color: #2c5282;
}

/* Entradas */
QLineEdit {
    background-color: white;
    border: 1px solid #dcdfe6;
    border-radius: 8px;
    padding: 8px;
}

QLineEdit:focus {
    border: 2px solid #3da5ff;
}

/* Botón calcular */
QPushButton#btnCalcular {
    background-color: #3da5ff;
    color: white;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 600;
}

QPushButton#btnCalcular:hover {
    background-color: #5ab3ff;
}

/* Botón cerrar */
QPushButton#btnCerrar {
    background-color: #e9ecef;
    color: #495057;
    border-radius: 8px;
    padding: 8px 16px;
}

QPushButton#btnCerrar:hover {
    background-color: #dee2e6;
}</string>
