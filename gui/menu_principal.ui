  <property name="styleSheet">
   <string notr="true">/* =========================
   ESTILO GENERAL DE APP
   ========================= */

QMainWindow {
    background-color: #f5f6f7;
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica&quot;, &quot;Arial&quot;;
    font-size: 18pt;
    color: #2c2c2c;
}

/* =========================
   MENU BAR
   ========================= */

QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #dcdcdc;
    padding: 6px;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 18px;
    border-radius: 6px;
}

QMenuBar::item:selected {
    background-color: #e8eef7;
}

QMenuBar::item:pressed {
    background-color: #d8e3f2;
}

/* =========================
   MENUS DESPLEGABLES
   ========================= */

QMenu {
    background-color: #ffffff;
    border: 1px solid #dcdcdc;
    padding: 6px;
}

QMenu::item {
    padding: 10px 30px;
    border-radius: 6px;
}

QMenu::item:selected {
    background-color: #e8eef7;
    color: #000000;
}

QMenu::separator {
    height: 1px;
    background: #dcdcdc;
    margin: 6px 10px;
}

/* =========================
   ACCIONES (QAction)
   ========================= */

QAction {
    padding: 10px;
}</string>
